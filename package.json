{
  "name": "my-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "postbuild": "pnpm dlx svelte-sitemap --out-dir .svelte-kit/cloudflare --domain https://nagoyc.stki.org --ignore 404",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.5",
    "@sveltejs/enhanced-img": "^0.9.2",
    "@sveltejs/kit": "^2.49.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.46.4",
    "svelte-check": "^4.3.5",
    "svelte-sitemap": "^3.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
